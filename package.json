{
  "name": "pitch-caller",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Dugout pitch-calling app — coach taps a pitch + location, catcher hears it in a Bluetooth earpiece.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "sync:ios": "cap sync ios && node scripts/register-ios-plugin.mjs",
    "ios:release": "npm run build && npm run sync:ios"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
